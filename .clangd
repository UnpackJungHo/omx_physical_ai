# clangd configuration for omx_ws
# 모든 .cpp/.hpp 에 공통 적용된다.

CompileFlags:
  # ROS2 / MoveIt 헤더가 C++17 기준으로 빌드되므로 동일하게 맞춘다.
  Add:
    - -std=c++17
    - -Wall
    - -Wextra
  # ROS rclcpp 의 일부 진단은 잡음이 많아 제외.
  Remove:
    - -W*deprecated-declarations
  # MoveIt 헤더가 c-style cast 를 많이 써서 진단 줄이기 위함.

Diagnostics:
  # missing include 같은 IntelliSense 잡음을 줄인다 (compile_commands.json 이 권위).
  UnusedIncludes: None
  # ros2 message 헤더에서 자주 나오는 가짜 경고들을 무시.
  Suppress:
    - unused-parameter
    - missing-field-initializers

# Index 옵션: 백그라운드에서 전체 인덱싱 (헤더까지 포함해서 jump-to-definition 향상)
Index:
  Background: Build

# 헤더-only 파일 (.hpp) 도 동일한 컴파일 플래그로 분석되도록 강제.
InlayHints:
  Enabled: No   # 처음엔 끄고, 익숙해지면 Yes 로 켤 것.
